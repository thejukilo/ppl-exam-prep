# Copy to mobile/.env and fill in.
# See docs/AUTH_SETUP.md for how to obtain each value.

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY

# --- Google Sign-In ---
# From Google Cloud Console > APIs & Services > Credentials
# Web client ID: type "Web application", used for token verification
GOOGLE_WEB_CLIENT_ID=

# iOS client ID: type "iOS"
GOOGLE_IOS_CLIENT_ID=
# The same iOS client ID, but reversed — Google's website shows you this
# verbatim on the credential page. Looks like: com.googleusercontent.apps.123-abc
GOOGLE_IOS_REVERSED_CLIENT_ID=
